{
  "_comment": "Group M, M5: probes whether Bash(git status:*) accepts suffix args. Allowlist contains ONLY Bash(git status:*) — NOT Bash(git:*) — so a successful git status --short run can be attributed unambiguously to the multi-word rule.",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Bash(git status:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git clone:*)",
      "Bash(git ls-remote:*)",
      "Bash(git remote:*)",
      "Bash(cd:*)",
      "Bash(git -C:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.ralph/hook-path-guard.py\""
          }
        ]
      }
    ]
  }
}
