{
  "_comment": "Group M, M4: probes whether Bash(rm:*) over-matches rmdir. Allowlist contains ONLY Bash(rm:*). If rmdir --help runs, the matcher does pure literal-prefix matching (security concern). If it denies, the matcher tokenises on word boundary (expected).",
  "permissions": {
    "defaultMode": "dontAsk",
    "allow": [
      "Read",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(git clone:*)",
      "Bash(git ls-remote:*)",
      "Bash(git remote:*)",
      "Bash(cd:*)",
      "Bash(git -C:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.ralph/hook-path-guard.py\""
          }
        ]
      }
    ]
  }
}
